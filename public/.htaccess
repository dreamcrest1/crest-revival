# ============================================================
# Dreamcrest Solutions — Apache config (cPanel / MilesWeb)
# ============================================================

# ---------- Force HTTPS + non-www canonical host ----------
RewriteEngine On
RewriteBase /

# Redirect HTTP -> HTTPS
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\. [NC]
RewriteRule ^(.*)$ https://dreamcrest.net/$1 [R=301,L]

# Strip trailing slashes (except root) for canonical URLs
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [R=301,L]

# ---------- SPA fallback ----------
RewriteRule ^index\.html$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]

# ---------- Security headers ----------
<IfModule mod_headers.c>
  # HSTS — 2 years, include subdomains, preload eligible
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# ---------- MIME types ----------
<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType image/avif .avif
  AddType application/manifest+json .webmanifest
  AddType application/javascript .mjs
</IfModule>

# ---------- Gzip / Deflate compression ----------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml application/x-font-ttf font/otf font/woff font/woff2
</IfModule>

# ---------- Browser caching (Expires) ----------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault                              "access plus 1 month"

  # HTML — short, so updates ship fast
  ExpiresByType text/html                     "access plus 0 seconds"

  # Data
  ExpiresByType application/json              "access plus 0 seconds"
  ExpiresByType application/xml               "access plus 0 seconds"
  ExpiresByType text/xml                      "access plus 0 seconds"

  # Manifest
  ExpiresByType application/manifest+json     "access plus 1 week"

  # Favicon
  ExpiresByType image/x-icon                  "access plus 1 year"

  # Images
  ExpiresByType image/jpeg                    "access plus 1 year"
  ExpiresByType image/png                     "access plus 1 year"
  ExpiresByType image/gif                     "access plus 1 year"
  ExpiresByType image/webp                    "access plus 1 year"
  ExpiresByType image/avif                    "access plus 1 year"
  ExpiresByType image/svg+xml                 "access plus 1 year"

  # Fonts
  ExpiresByType font/woff                     "access plus 1 year"
  ExpiresByType font/woff2                    "access plus 1 year"
  ExpiresByType application/x-font-ttf        "access plus 1 year"
  ExpiresByType font/otf                      "access plus 1 year"

  # CSS / JS — hashed by Vite, so cache forever
  ExpiresByType text/css                      "access plus 1 year"
  ExpiresByType application/javascript        "access plus 1 year"
  ExpiresByType text/javascript               "access plus 1 year"
</IfModule>

# ---------- Cache-Control headers ----------
<IfModule mod_headers.c>
  # Hashed bundles (Vite output) — immutable
  <FilesMatch "\.(js|css|woff2|woff|ttf|otf|webp|avif|jpg|jpeg|png|gif|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # HTML and manifest — must revalidate
  <FilesMatch "\.(html|json|xml|webmanifest)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>

# ---------- Custom 404 — let SPA handle it ----------
ErrorDocument 404 /index.html
